[user]
	name = Sagi Schwarz
	email = mail@sagischwarz.de
	signingkey = 1EE83B72F09B272B
[credential]
	helper = store
[core]
	fileMode = false
	autocrlf = input
	pager = delta
	editor = \\vim
[push]
	autoSetupRemote = true
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	syntax-theme = none
	line-numbers = true
	side-by-side = true
	minus-style = 'red'
	plus-style = 'green'
	minus-emph-style = 'black bold red'
	plus-emph-style = 'black bold green'
	line-numbers-minus-style = 'red'
	line-numbers-plus-style = 'green'
[color]
	ui = auto
[alias]
	dt = difftool
	lgc = log --color --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an [%G?]>%Creset' --abbrev-commit --graph
	lg = lgc --branches --tags
	fm = lg --all -i -F --grep
	fc = lg --all -i -S
	d = diff
	ds = diff --staged
	tt = ! git for-each-ref --sort=-creatordate --format '%(creatordate:short) %(objectname:short) %(refname:strip=2)' refs/tags | head -n 10
	akd = !GIT_COMMITTER_DATE=\"$(git log -1 --format=%cI)\" git commit --amend --date=\"$(git log -1 --format=%aI)\"
[diff]
	external = difft
	tool = vscode
	colorMoved = default
	algorithm = histogram
	ignoreSubmodules = dirty
[merge]
	tool = vscode
	conflictStyle = zdiff3
[difftool]
	prompt = false
[difftool "vscode"]
	cmd = code --wait --diff --new-window $LOCAL $REMOTE
[mergetool "vscode"]
	cmd = code --wait --new-window $MERGED
[pull]
	rebase = true
[pager]
	branch = false
[commit]
	gpgsign = true
[init]
	defaultBranch = main
